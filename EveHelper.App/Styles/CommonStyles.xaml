<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Common Button Styles -->
    <Style x:Key="EveButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Background" Value="{StaticResource EveOrangeBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- Common Card Style -->
    <Style x:Key="EveCardStyle" TargetType="materialDesign:Card">
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp4"/>
    </Style>

    <!-- Common TextBlock Styles -->
    <Style x:Key="EveHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline4TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource EveGoldBrush}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <Style x:Key="EveSubHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource EveOrangeBrush}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Common ListBox Style -->
    <Style x:Key="EveListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource MaterialDesignListBox}">
        <Setter Property="Margin" Value="5"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Common TextBox Style -->
    <Style x:Key="EveTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Margin" Value="5"/>
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
    </Style>

</ResourceDictionary> 