<UserControl x:Class="EveHelper.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:EveHelper.App.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <!-- Welcome Section -->
                <materialDesign:Card Style="{StaticResource EveCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding WelcomeMessage}" 
                                   Style="{StaticResource EveHeaderTextStyle}"/>
                        <TextBlock Text="Your intelligent ship fitting companion" 
                                   Style="{StaticResource EveSubHeaderTextStyle}"/>
                        <TextBlock Text="This application helps you optimize ship fittings based on your skills and objectives. Get started by selecting a ship from the browser or exploring the fitting tool."
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,16"/>
                        
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Browse Ships" 
                                    Style="{StaticResource EveButtonStyle}"
                                    Command="{Binding BrowseShipsCommand}"/>
                            <Button Content="Open Fitting Tool" 
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding OpenFittingToolCommand}"
                                    Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Quick Actions -->
                <materialDesign:Card Style="{StaticResource EveCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Quick Actions" 
                                   Style="{StaticResource EveSubHeaderTextStyle}"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0" 
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding BrowseShipsCommand}"
                                    Margin="0,0,8,0"
                                    Height="80">
                                <StackPanel HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Ship" 
                                                             Height="24" 
                                                             Width="24" 
                                                             HorizontalAlignment="Center"
                                                             Margin="0,0,0,8"/>
                                    <TextBlock Text="Ship Browser" 
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Grid.Column="1" 
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding OpenFittingToolCommand}"
                                    Margin="4,0"
                                    Height="80">
                                <StackPanel HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Wrench" 
                                                             Height="24" 
                                                             Width="24" 
                                                             HorizontalAlignment="Center"
                                                             Margin="0,0,0,8"/>
                                    <TextBlock Text="Fitting Tool" 
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Grid.Column="2" 
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding OpenSkillPlannerCommand}"
                                    Margin="8,0,0,0"
                                    Height="80">
                                <StackPanel HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="School" 
                                                             Height="24" 
                                                             Width="24" 
                                                             HorizontalAlignment="Center"
                                                             Margin="0,0,0,8"/>
                                    <TextBlock Text="Skill Planner" 
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Status Section -->
                <materialDesign:Card Style="{StaticResource EveCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Status" 
                                   Style="{StaticResource EveSubHeaderTextStyle}"/>
                        <TextBlock Text="{Binding StatusMessage}" 
                                   Foreground="{StaticResource EveGoldBrush}"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Features Preview -->
                <materialDesign:Card Style="{StaticResource EveCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Upcoming Features" 
                                   Style="{StaticResource EveSubHeaderTextStyle}"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <materialDesign:Chip Content="Intelligent Fitting" 
                                                     Icon="Brain" 
                                                     Margin="0,4"/>
                                <materialDesign:Chip Content="Skill Analysis" 
                                                     Icon="School" 
                                                     Margin="0,4"/>
                                <materialDesign:Chip Content="Market Integration" 
                                                     Icon="TrendingUp" 
                                                     Margin="0,4"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <materialDesign:Chip Content="ESI Integration" 
                                                     Icon="Api" 
                                                     Margin="0,4"/>
                                <materialDesign:Chip Content="Fitting Export" 
                                                     Icon="Export" 
                                                     Margin="0,4"/>
                                <materialDesign:Chip Content="Real-time Stats" 
                                                     Icon="ChartLine" 
                                                     Margin="0,4"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl> 